{
  "$schema": "https://design-tokens.org/schema.json",
  "input": {
    "base": {
      "bg":            { "$value": "{surface.elev-1}", "$type": "color" },
      "border-color":  { "$value": "{surface.border}", "$type": "color" },
      "border-width":  { "$value": "1px",              "$type": "dimension" },
      "border-radius": { "$value": "{radius.sm}",      "$type": "dimension" },
      "padding-x":     { "$value": "{spacing.4}",      "$type": "dimension" },
      "padding-y":     { "$value": "{spacing.3}",      "$type": "dimension" },
      "color":         { "$value": "{text.primary}",   "$type": "color" },
      "placeholder":   { "$value": "{text.tertiary}",  "$type": "color" },
      "font":          { "$value": "{type.body}",      "$type": "typography" },
      "min-height":    { "$value": "44px",             "$type": "dimension" },
      "transition":    { "$value": "{motion.duration.instant} {motion.ease.axial}", "$type": "transition" }
    },
    "state": {
      "hover-border":  { "$value": "{surface.border-strong}", "$type": "color" },
      "focus-border":  { "$value": "{color.axial.voltage}",   "$type": "color" },
      "focus-shadow":  { "$value": "{shadow.focus-ring}",     "$type": "shadow" },
      "error-border":  { "$value": "{color.axial.plasma}",    "$type": "color" },
      "disabled-bg":   { "$value": "{surface.elev-1}",        "$type": "color" },
      "disabled-color":{ "$value": "{text.tertiary}",         "$type": "color" }
    },
    "label": {
      "font":  { "$value": "{type.eyebrow}",   "$type": "typography" },
      "color": { "$value": "{text.secondary}", "$type": "color" },
      "margin-bottom": { "$value": "{spacing.2}", "$type": "dimension" }
    },
    "helper": {
      "font":  { "$value": "{type.caption}",   "$type": "typography" },
      "color": { "$value": "{text.tertiary}",  "$type": "color" },
      "margin-top": { "$value": "{spacing.2}", "$type": "dimension" }
    }
  }
}
