{
  "$schema": "https://design-tokens.org/schema.json",
  "card": {
    "base": {
      "bg":            { "$value": "{surface.elev-1}", "$type": "color" },
      "border-color":  { "$value": "{surface.border}", "$type": "color" },
      "border-width":  { "$value": "1px",              "$type": "dimension" },
      "border-radius": { "$value": "{radius.none}",    "$type": "dimension", "$description": "No corner radius. Right angles are the brand." },
      "padding":       { "$value": "{spacing.8}",      "$type": "dimension" },
      "shadow":        { "$value": "{shadow.none}",    "$type": "shadow" },
      "transition":    { "$value": "{motion.duration.ui} {motion.ease.axial}", "$type": "transition" }
    },
    "service": {
      "$description": "Service cards in 4-up grids. No bg fill. Border becomes Voltage on hover. Number index in Mono top-left.",
      "bg":              { "$value": "transparent", "$type": "color" },
      "padding":         { "$value": "{spacing.6}", "$type": "dimension" },
      "min-height":      { "$value": "240px",        "$type": "dimension" },
      "hover-border":    { "$value": "{color.axial.voltage}", "$type": "color" },
      "hover-arrow-tx":  { "$value": "4px", "$type": "dimension", "$description": "Arrow translateX on hover." }
    },
    "pricing-default": {
      "$description": "Standard pricing tier. Border, no bg.",
      "bg":           { "$value": "transparent", "$type": "color" },
      "border-color": { "$value": "{surface.border}", "$type": "color" },
      "padding":      { "$value": "{spacing.10}", "$type": "dimension" }
    },
    "pricing-signature": {
      "$description": "Signature middle tier. Voltage outline + soft glow.",
      "bg":           { "$value": "transparent", "$type": "color" },
      "border-color": { "$value": "{color.axial.voltage}", "$type": "color" },
      "border-width": { "$value": "1px", "$type": "dimension" },
      "shadow":       { "$value": "{shadow.glow-soft}", "$type": "shadow" },
      "padding":      { "$value": "{spacing.10}", "$type": "dimension" }
    },
    "case-study": {
      "$description": "Case study index card. Image top, metadata Mono, title Display.",
      "bg":           { "$value": "{surface.elev-1}", "$type": "color" },
      "border-color": { "$value": "{surface.border}", "$type": "color" },
      "padding":      { "$value": "{spacing.0}", "$type": "dimension" },
      "image-aspect": { "$value": "4 / 3", "$type": "string" }
    }
  }
}
