{
  "$schema": "https://design-tokens.org/schema.json",
  "spacing": {
    "0":   { "$value": "0px",   "$type": "dimension" },
    "1":   { "$value": "4px",   "$type": "dimension", "$description": "Base unit. Everything aligns to multiples of this." },
    "2":   { "$value": "8px",   "$type": "dimension" },
    "3":   { "$value": "12px",  "$type": "dimension" },
    "4":   { "$value": "16px",  "$type": "dimension" },
    "5":   { "$value": "20px",  "$type": "dimension" },
    "6":   { "$value": "24px",  "$type": "dimension", "$description": "Default gutter for marketing grid." },
    "8":   { "$value": "32px",  "$type": "dimension" },
    "10":  { "$value": "40px",  "$type": "dimension" },
    "12":  { "$value": "48px",  "$type": "dimension" },
    "16":  { "$value": "64px",  "$type": "dimension" },
    "20":  { "$value": "80px",  "$type": "dimension" },
    "24":  { "$value": "96px",  "$type": "dimension" },
    "32":  { "$value": "128px", "$type": "dimension" },
    "48":  { "$value": "192px", "$type": "dimension" },
    "64":  { "$value": "256px", "$type": "dimension" }
  },
  "layout": {
    "max-width": {
      "prose":     { "$value": "640px",  "$type": "dimension" },
      "container": { "$value": "1280px", "$type": "dimension" },
      "wide":      { "$value": "1440px", "$type": "dimension" }
    },
    "gutter": {
      "marketing": { "$value": "24px", "$type": "dimension" },
      "product":   { "$value": "16px", "$type": "dimension" }
    },
    "columns": {
      "marketing": { "$value": 12, "$type": "number" },
      "product":   { "$value": 8,  "$type": "number" }
    },
    "breakpoint": {
      "xs":  { "$value": "0px",    "$type": "dimension" },
      "sm":  { "$value": "480px",  "$type": "dimension" },
      "md":  { "$value": "768px",  "$type": "dimension" },
      "lg":  { "$value": "1024px", "$type": "dimension" },
      "xl":  { "$value": "1280px", "$type": "dimension" },
      "2xl": { "$value": "1440px", "$type": "dimension" }
    }
  }
}
