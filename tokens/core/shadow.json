{
  "$schema": "https://design-tokens.org/schema.json",
  "shadow": {
    "none":         { "$value": "none", "$type": "shadow" },
    "border-z1":    { "$value": "inset 0 0 0 1px {color.graphite.700}", "$type": "shadow", "$description": "Z1 elevation in dark mode. Border, not shadow." },
    "border-z1-light": { "$value": "inset 0 0 0 1px {color.graphite.200}", "$type": "shadow", "$description": "Z1 elevation in light mode." },
    "z2-popover":   { "$value": "0 8px 24px rgba(10, 10, 11, 0.4), inset 0 0 0 1px {color.graphite.700}", "$type": "shadow", "$description": "Z2 dropdowns and popovers." },
    "z2-popover-light": { "$value": "0 8px 24px rgba(10, 10, 11, 0.08), inset 0 0 0 1px {color.graphite.200}", "$type": "shadow" },
    "z3-modal":     { "$value": "0 24px 64px rgba(10, 10, 11, 0.6)", "$type": "shadow", "$description": "Z3 modals (paired with backdrop blur)." },
    "glow-soft":    { "$value": "0 0 24px rgba(198, 242, 78, 0.35)", "$type": "shadow", "$description": "Soft Voltage glow. Hover state on primary CTAs." },
    "glow-strong":  { "$value": "0 0 48px rgba(198, 242, 78, 0.55), 0 0 96px rgba(198, 242, 78, 0.25)", "$type": "shadow", "$description": "Strong Voltage glow. Signature pricing tier only." },
    "focus-ring":   { "$value": "0 0 0 2px {color.axial.black}, 0 0 0 4px {color.axial.voltage}", "$type": "shadow", "$description": "2px Voltage focus ring offset 2px from element." }
  },
  "blur": {
    "scrim":   { "$value": "12px", "$type": "dimension", "$description": "Backdrop blur on Z3 modal scrims." },
    "subtle":  { "$value": "4px",  "$type": "dimension" }
  }
}
